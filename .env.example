# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=sales_db

# JWT
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=7d

# Files
UPLOAD_PATH=public/files
PHOTOS_PATH=public/files/photos
TEMP_PATH=public/files/temp
MAX_FILE_SIZE=5242880
