### ==========================================
### BRAND — RUTAS PÚBLICAS
### ==========================================

### Get all brands SIN parámetros (sin token — público ✅)
GET {{baseUrl}}/brand/ HTTP/1.1

### ==========================================

### Get brand by ID (válido — público ✅)
GET {{baseUrl}}/brand/{{brandId}} HTTP/1.1

### ==========================================

### Get brand by ID (no existe — 404)
GET {{baseUrl}}/brand/999 HTTP/1.1

### ==========================================

### Get brand by ID (id inválido — 422)
GET {{baseUrl}}/brand/abc HTTP/1.1


### ==========================================
### BRAND — CREATE (admin + editor)
### ==========================================

### Create brand (admin — válido ✅ 201)
POST {{baseUrl}}/brand/ HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Basement"
}

### ==========================================

### Create brand (editor — válido ✅ 201)
POST {{baseUrl}}/brand/ HTTP/1.1
Authorization: Bearer {{editorToken}}
Content-Type: application/json

{
    "name": "Adidas"
}

### ==========================================

### Create brand (customer — 403 Forbidden ❌)
POST {{baseUrl}}/brand/ HTTP/1.1
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
    "name": "Puma"
}

### ==========================================

### Create brand (sin token — 401 Unauthorized ❌)
POST {{baseUrl}}/brand/ HTTP/1.1
Content-Type: application/json

{
    "name": "Puma"
}

### ==========================================

### Create brand (name vacío — 422 ❌)
POST {{baseUrl}}/brand/ HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": ""
}

### ==========================================

### Create brand (name muy corto — 422 ❌)
POST {{baseUrl}}/brand/ HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "A"
}


### ==========================================
### BRAND — UPDATE (admin + editor)
### ==========================================

### Update brand (admin — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Basement Updated"
}

### ==========================================

### Update brand (editor — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{editorToken}}
Content-Type: application/json

{
    "name": "Basement Updated By Editor"
}

### ==========================================

### Update brand (customer — 403 ❌)
PATCH {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
    "name": "Basement Updated"
}

### ==========================================

### Update brand (sin token — 401 ❌)
PATCH {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Content-Type: application/json

{
    "name": "Basement Updated"
}

### ==========================================

### Update brand (no existe — 404 ❌)
PATCH {{baseUrl}}/brand/999 HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Basement Updated"
}


### ==========================================
### BRAND — ACTIVATE / DEACTIVATE (admin + editor)
### ==========================================

### Activate brand (admin — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}}/activate HTTP/1.1
Authorization: Bearer {{adminToken}}

### ==========================================

### Activate brand (editor — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}}/activate HTTP/1.1
Authorization: Bearer {{editorToken}}

### ==========================================

### Activate brand (customer — 403 ❌)
PATCH {{baseUrl}}/brand/{{brandId}}/activate HTTP/1.1
Authorization: Bearer {{customerToken}}

### ==========================================

### Activate brand (sin token — 401 ❌)
PATCH {{baseUrl}}/brand/{{brandId}}/activate HTTP/1.1

### ==========================================

### Activate brand (no existe — 404 ❌)
PATCH {{baseUrl}}/brand/999/activate HTTP/1.1
Authorization: Bearer {{adminToken}}

### ==========================================

### Deactivate brand (admin — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}}/deactivate HTTP/1.1
Authorization: Bearer {{adminToken}}

### ==========================================

### Deactivate brand (editor — válido ✅)
PATCH {{baseUrl}}/brand/{{brandId}}/deactivate HTTP/1.1
Authorization: Bearer {{editorToken}}

### ==========================================

### Deactivate brand (customer — 403 ❌)
PATCH {{baseUrl}}/brand/{{brandId}}/deactivate HTTP/1.1
Authorization: Bearer {{customerToken}}

### ==========================================

### Deactivate brand (no existe — 404 ❌)
PATCH {{baseUrl}}/brand/999/deactivate HTTP/1.1
Authorization: Bearer {{adminToken}}


### ==========================================
### BRAND — DELETE (solo admin)
### ==========================================

### Delete brand (admin — válido ✅)
DELETE {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{adminToken}}

### ==========================================

### Delete brand (editor — 403 ❌ solo admin puede eliminar)
DELETE {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{editorToken}}

### ==========================================

### Delete brand (customer — 403 ❌)
DELETE {{baseUrl}}/brand/{{brandId}} HTTP/1.1
Authorization: Bearer {{customerToken}}

### ==========================================

### Delete brand (sin token — 401 ❌)
DELETE {{baseUrl}}/brand/{{brandId}} HTTP/1.1

### ==========================================

### Delete brand (no existe — 404 ❌)
DELETE {{baseUrl}}/brand/999 HTTP/1.1
Authorization: Bearer {{adminToken}}